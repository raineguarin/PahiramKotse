<!DOCTYPE html>
<html>
<head>
    <title>Manage Vehicles</title>
    <link rel="stylesheet" href="/manage-vehicles.css">
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
</head>

<body>
    <div class="header-flex">
        <div class="logo">
            <img src="/images/logo.png" width="300px">
        </div>
        <ul class="navlinks">
            <li><a href="/admin-homepage">To Dashboard</a></li>
            <li>
                <a href="/admin-profile">
                <img src="/profilepicture.png" alt="Profile" width="40px" height="40px" style="border-radius:50%;">
                </a>
            </li>
        </ul>
    </div>

    <div class="name">
        <h1>Manage Vehicles</h1>
        <p>Admin</p>
    </div>

    <div class="boxcontainer">

        <div class="icons">
            <button><i class="fa-solid fa-plus"></i> Add</button>
            <button><i class="fa-solid fa-pen-to-square"></i> Edit</button>
            <button><i class="fa-solid fa-trash"></i> Delete</button>
            <button><i class="fa-solid fa-upload"></i> Upload Image</button>
        </div>

        <div class="vehicle-grid">
            {{#each vehicles}}
            <div class="vehicle-card">
                <img src="{{this.image}}" alt="{{this.brand}} {{this.model}}">

                <div class="vehicle-info">
                    <p><strong>Brand:</strong> {{this.brand}}</p>
                    <p><strong>Model:</strong> {{this.model}}</p>
                    <p><strong>Type:</strong> {{this.carType}}</p>
                    <p><strong>Capacity:</strong> {{this.capacity}}-Seater</p>
                    <p><strong>Daily Rate:</strong> ₱{{this.dailyRate}}</p>
                    <p><strong>Status:</strong> {{this.status}}</p>
                </div>
            </div>
            {{/each}}
        </div>
    </div>

    <footer>
        <div class="footerContainer">
            <a href="/manage-users" class="disable-link">Manage Users</a>
            <a href="/manage-vehicles" class="disable-link">Manage Vehicles</a>
            <a href="/manage-reservations" class="disable-link">Manage Reservations</a>
        </div>
    </footer>

</body>
</html>