<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>Our Vehicles - PahiramKotse</title>
        <link rel="stylesheet" href="/global.css">
        <link rel="stylesheet" href="/cars.css">
    </head>
    
    <body>
        <div class="header-flex">
            <div class="logo">
                <a href="/">
                    <img src="/logo.png" width="300px" alt="Logo">
                </a>
            </div>

            <ul class="navlinks">
                <li><a href="/cars">Our Vehicles</a></li>
                <li><a href="/search">Search a Car</a></li>
                <li><a href="/friends">Friends</a></li>
                <li><a href="/reservations">My Reservations</a></li>
                <li>
                    <a href="/profile">
                        <img src="/profilepicture.png" alt="Profile" width="40px" height="40px" style="border-radius:50%;">
                    </a>
                </li>
            </ul>
        </div>
        <div class="filter">
            </div>

        <div class="boxcontainer">
            {{#each vehicles}}
            <div class="boxcars">
                <img src="{{this.image}}" alt="{{this.brand}} {{this.model}}">
                <div class="boxcarsinfo">
                    <h2>{{this.brand}} {{this.model}}</h2>
                    <h3>{{this.capacity}}-Seater</h3>
                    
                    <h3>{{#if this.status}}Available{{else}}Not-Available{{/if}}</h3>
                    
                    <a href="#" class="disable-linkcars" data-car="{{this._id}}" data-name="{{this.brand}} {{this.model}}"> Click to see Reviews</a>
                    
                    <button type="button" class="proceed"
                        onclick="openReserveModal('{{this._id}}','{{this.brand}} {{this.model}}')"
                        {{#unless this.status}}disabled style="background-color: grey; cursor: not-allowed;"{{/unless}}>
                        Reserve
                    </button>
                </div>
            </div>
            <hr> <br>
            {{/each}}
        </div>

        <footer>
            <div class="footerContainer">
                <p> This is an MCO project for GDAPDEV XX22 by Group 4. </p>
                <a href="/contact" class="disable-link"> Contact Us</a>
            </div>
        </footer>
            
        <div id="reviewPopup" class="popup">
            <div class="Popupcontent">
                <span class="reviewclose">&times;</span>
                <h2 id="reviewTitle">Reviews</h2>
                <hr>
                <div id="reviewbody"></div>
            </div>
        </div>
        
        <div id="reservePopup" class="popup">
            <div class="Popupcontent">
                <span class="reserveclose">&times;</span>
                <h2 id="reserveTitle">Reserve Vehicle</h2>
                <hr>
                <form id="reserveForm">
                    <input type="hidden" id="reserveCarId">
                    <p><strong>Vehicle:</strong> <span id="displayCarName"></span></p>

                    <label for="reserveDate">Pick a Date:</label><br>
                    <input type="date" id="reserveDate" required style="width: 100%; padding: 8px; margin: 10px 0;">

                    <div style="display: flex; gap: 10px; margin-top: 10px;">
                        <div style="flex: 1;">
                            <label>Pickup Time:</label><br>
                            <input type="time" id="startTime" required style="width: 100%; padding: 8px; margin: 5px 0;">
                        </div>
                        <div style="flex: 1;">
                            <label>Return Time:</label><br>
                            <input type="time" id="endTime" required style="width: 100%; padding: 8px; margin: 5px 0;">
                        </div>
                    </div>

                    <button type="submit" class="proceed" style="width: 100%; margin-top: 20px;">Confirm Reservation</button>
                </form>
            </div>
        </div>

        <script src="/js/cars.js"></script>
    </body>
</html>