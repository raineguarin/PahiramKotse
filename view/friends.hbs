<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Friends</title>
    <link rel="stylesheet" href="/global.css">
    <link rel = "stylesheet" href = "/friends.css">
</head>
<body>
    <div class="header-flex">
        <div class="logo">
            <a href="/">
            <img src="/logo.png" width="300px" alt="Logo">
            </a>
        </div>

        <ul class="navlinks">
            <li><a href="/cars">Our Vehicles</a></li>
            <li><a href="/search">Search a Car</a></li>
            <li><a href="/friends">Friends</a></li>
            <li><a href="/reservations">My Reservations</a></li>
            <li>
                <a href="/profile">
                    <img src="/images/{{user.profilePicture}}" alt="Profile" width="40px" height="40px" style="border-radius:50%; object-fit: cover;">
                </a>
            </li>
        </ul>
    </div>

    <h2 class="friendsheader">Reviews from your Friends</h2>

    <div class="boxcontainer">
        {{#each friendReviews}}
        <div class="boxfriends">
            <h2>{{this.user.name}}</h2>
            <h4>{{this.car.brand}} {{this.car.model}}</h4>
            <p>{{this.title}}</p>
            <p>{{this.description}}</p>
        </div>
    {{/each}}

    <h2 class="friendsheader">Reviews from other People</h2>

    <div id="friendAdd" class="friendNotification"> </div>

        {{#each otherReviews}}
        <div class="boxfriends">
            <h2>{{this.user.name}}</h2>
            <h4>{{this.car.brand}} {{this.car.model}}</h4>
            <p>{{this.title}}</p>
            <p>{{this.description}}</p>
            <button class="addfriend" data-userid="{{this.user._id}}">Add Friend</button>
        </div>
    {{/each}}
    </div>

    <footer>
        <div class="footerContainer">
            <p> This is an MCO project for GDAPDEV XX22 by Group 4. </p>
            <a href="/contact-us" class="disable-link"> Contact Us</a>
            <p style="color: white;"> | </p>
            <a href="/about" class="disable-link">  About</a>
        </div>
    </footer>

    </div>

    <script src="/friends.js"></script>
</body>
</html>