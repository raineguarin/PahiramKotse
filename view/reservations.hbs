<!DOCTYPE html>
<html>
<head>
    <title>My Reservations - PahiramKotse</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/friends.css">
</head>

<body>

    <div class="header-flex">
        <div class="logo">
            <a href="/">
                <img src="/logo.png" width="300px">
            </a>
        </div>

        <ul class="navlinks">
            <li><a href="/cars">Our Vehicles</a></li>
            <li><a href="/search">Search a Car</a></li>
            <li><a href="/friends">Friends</a></li>
            <li><a href="/reservations">My Reservations</a></li>
            <li>
                <a href="/profile">
                    <img src="/profilepicture.png" alt="Profile" width="40px" height="40px" style="border-radius:50%;">
                </a>
            </li>
        </ul>
    </div>

    <h2 class="friendsheader">Processing Reservations</h2>
    <div class="boxcontainer">
        {{#each processing}}
        <div class="boxfriends" id="res-{{this._id}}"> <h2>{{this.vehicle.brand}} {{this.vehicle.model}}</h2>
            <h4>Date: {{this.date}}</h4>
            <h4>Time: {{this.time}}</h4>
            <p>Reservation is still processing, awaiting admin confirmation</p>
            <p><strong>Status:</strong> <span style="color: orange;">{{this.status}}</span></p>
            
            <button class="review" 
                    style="background-color: #ff4d4d; margin-top: 10px;" 
                    onclick="cancelReservation('{{this._id}}')">
                Cancel Reservation
            </button>
        </div>
        {{else}}
        <p style="text-align: center; color: #666; width: 100%;">No pending reservations.</p>
        {{/each}}
    </div>

    <h2 class="friendsheader">Ongoing Reservations</h2>
    <div class="boxcontainer">
        {{#each ongoing}}
        <div class="boxfriends">
            <h2>{{this.vehicle.brand}} {{this.vehicle.model}}</h2>
            <h4>Date: {{this.date}}</h4>
            <h4>Time: {{this.time}}</h4>
            <p>Reservation is currently active</p>
            <p><strong>Payment:</strong> {{this.paymentStatus}}</p>
        </div>
        {{else}}
        <p style="text-align: center; color: #666; width: 100%;">No ongoing reservations.</p>
        {{/each}}
    </div>

    <h2 class="friendsheader">Completed Reservations</h2>
    <div class="boxcontainer">
        {{#each completed}}
        <div class="boxfriends">
            <h2>{{this.vehicle.brand}} {{this.vehicle.model}}</h2>
            <h4>Date: {{this.date}}</h4>
            <p>Reservation completed successfully</p>
            <br> 
            <button class="review" onclick="window.location.href='/review/{{this.vehicle._id}}'">Make a Review</button>
        </div>
        {{else}}
        <p style="text-align: center; color: #666; width: 100%;">No completed reservations.</p>
        {{/each}}
    </div>

    <footer>
        <div class="footerContainer">
            <p> This is an MCO project for GDAPDEV XX22 by Group 4. </p>
            <a href="/contact-us" class="disable-link"> Contact Us</a>
        </div>
    </footer>


<script>
async function cancelReservation(reservationId) {
    if (!confirm("Are you sure you want to cancel this reservation?")) return;

    try {
        const response = await fetch('/cancel', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ reservationId })
        });

        if (response.ok) {
            alert("Reservation cancelled successfully.");

            document.getElementById(`res-${reservationId}`).remove();
        } else {
            const err = await response.json();
            alert("Error: " + err.error);
        }
    } catch (error) {
        console.error("Cancel error:", error);
        alert("Could not connect to the server.");
    }
}
</script>

</body>
</html>