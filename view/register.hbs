<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Registration - PahiramKotse</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/register.css">
</head>
<body>

    <div class="header-flex">
        <div class="logo">
            <img src="/images/logo.png" width="300px">
        </div>
        <ul class="navlinks">
            <li><h3>Rent a car now!</h3></li>
            <li>
                <a href="/login" class="regbtn" style="padding: 10px 20px; text-decoration: none;">Login</a>
            </li>
        </ul>
    </div>

    <div class="home-flex">
        <div class="home-left">
            <h2>Create Your Account</h2>
            <p>Join PahiramKotse today and get access to the best vehicle rentals in the city.</p>
            <div class="desc">
                <img src="/images/logo.png" width="100%" style="opacity: 0.1; position: absolute; left: 0; z-index: -1;">
            </div>
        </div>

        <div class="home-right">
            <section class="carssection">
                <div class="userDetails">
                    <h2>Registration Details</h2>
                    
                    <div class="input-group">
                        <label for="regName">Full Name:</label>
                        <div class="nameInput">
                            <input type="text" id="regName" placeholder="e.g. Ashton Jude Ching">
                            <span id="nameError" class="error-msg"></span> 
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="regEmail">Email Address:</label>
                        <div class="emailInput"> 
                            <input type="text" id="regEmail" placeholder="example@email.com">
                            <span id="emailError" class="error-msg"></span> 
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="regNumber">Phone Number:</label>
                        <div class="numberInput">
                            <input type="text" id="regNumber" placeholder="09123456789">
                            <span id="numberError" class="error-msg"></span>
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="regPass">Password:</label>
                        <div class="passInput" style="position: relative;">
                            <input type="password" id="regPass" placeholder="At least 8 characters">
                            <span id="togglePass" style="position: absolute; right: 10px; top: 12px; cursor: pointer; font-size: 12px; color: #3db7dd;">Show Password</span>
                            <span id="passError" class="error-msg"></span> 
                        </div>
                    </div>

                    <div class="input-group">
                        <label for="regImage">Profile Image:</label>
                        <div class="imageInput">
                            <input type="file" id="regImage" accept="image/*">
                        </div>
                    </div>

                    <br>
                    <div class="proceed">
                        <button class="regbtn" style="width: 100%; cursor: pointer;">Proceed to Login</button>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script src="/js/register.js"></script>
</body>
</html>