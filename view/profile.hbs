<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Profile</title>
    <link rel="stylesheet" href="/global.css">
    <link rel="stylesheet" href="/profile.css">
</head>

<body>
    <div class="header-flex">
        <div class="logo">
            <a href="/">
                <img src="/logo.png" width="300px" alt="Logo">
            </a>
        </div>

        <ul class="navlinks">
            <li><a href="/cars">Our Vehicles</a></li>
            <li><a href="/search">Search a Car</a></li>
            <li><a href="/friends">Friends</a></li>
            <li><a href="/reservations">My Reservations</a></li>
            <li>
                <a href="/profile">
                    <img src="/images/{{user.profilePicture}}" alt="Profile" width="40px" height="40px" style="border-radius:50%; object-fit: cover;">
                </a>
            </li>
        </ul>
    </div>

    <div class="boxcontainerprofile">
        <div class="profile-info">
            <a href="/profile">
                <img src="/images/{{user.profilePicture}}" alt="Profile" width="40px" height="40px" style="border-radius:50%; object-fit: cover;">
            </a>
            <h2>{{user.name}}</h2>
            <h4>Private Profile</h4>
            <h4 id="logoutbtn" style="color:red; cursor: pointer;">Log Out</h4>
        </div>
        
        <div class="profile-reviews">
            <h4>Your Reviews</h4>
            
            {{#if reviews.length}}
                {{#each reviews}}
                <div class="boxfriends">
                    <h2>{{this.title}}</h2> 
                    
                    <h4 style="color: #3db7dd;">Rented {{this.car.brand}} {{this.car.model}}</h4> 
                    
                    <p>{{this.description}}</p>
                </div>
                {{/each}}
            {{else}}
                <p style="color: #b9d9e8; font-style: italic; margin-top: 15px;">You haven't written any reviews yet.</p>
            {{/if}}
        </div>
    </div>

    <footer>
        <div class="footerContainer">
            <p> This is an MCO project for GDAPDEV XX22 by Group 4. </p>
            <a href="/contact-us" class="disable-link"> Contact Us</a>
            <p style="color: white;"> | </p>
            <a href="/about" class="disable-link">  About</a>
        </div>
    </footer>

    <div id="logout" class="Popup">
        <div class="Popupcontent">
            <h2>Log Out</h2>
            <hr>
            <p>Logging out?</p>
            <div class="logoutbuttons" style="display: flex; justify-content: center; gap: 10px; margin-top: 20px;">
                <button class="cancel" id="logoutCancel">Cancel</button>
                <button class="proceed" id="logoutConfirm" style="background-color: red;">Log Out</button>
            </div>
        </div>
    </div>

    <script src="/profile.js"></script>
</body>
</html>